# Database
# PostgreSQL 접속 문자열입니다.
# 형식: postgresql://사용자:비밀번호@호스트:포트/DB명?schema=스키마명&connection_limit=최대커넥션수
# - voxion_db: 이 앱이 사용할 데이터베이스 이름입니다. 없으면 먼저 생성해야 합니다.
# - schema=public: Prisma가 사용할 PostgreSQL schema입니다.
# - connection_limit=5: Prisma가 열 수 있는 DB 커넥션 수를 낮게 제한합니다. 개인용 로컬 실행이면 5면 충분합니다.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/voxion_db?schema=public&connection_limit=5"

# Redis Configuration
# BullMQ 작업 큐가 사용할 Redis 설정입니다.
# 다른 프로젝트와 같은 Redis를 공유할 때는 REDIS_KEY_PREFIX를 다르게 잡아 큐 키 충돌을 피합니다.
REDIS_KEY_PREFIX=local:

# Redis 서버 위치입니다. Docker Redis를 로컬 포트로 열어둔 경우 localhost를 사용합니다.
REDIS_HOST=localhost

# Redis 포트입니다. 기본 Redis 포트는 6379입니다.
REDIS_PORT=6379

# Redis 비밀번호입니다. 비밀번호가 없으면 빈 값으로 둡니다.
# 예: REDIS_PASSWORD=redis123
REDIS_PASSWORD=

# Redis logical database 번호입니다. 같은 Redis 안에서 앱별로 DB를 나누고 싶을 때 변경합니다.
REDIS_DB=0

# Redis 캐시성 데이터의 기본 TTL 초 단위입니다. 현재 설정값 300은 5분입니다.
REDIS_TTL=300

# Redis 명령 재시도 횟수입니다. 로컬 개발에서는 3 정도면 충분합니다.
REDIS_MAX_RETRIES=3

# Redis 연결 타임아웃입니다. 밀리초 단위이며 10000은 10초입니다.
REDIS_CONNECT_TIMEOUT=10000

# true면 Redis 연결을 실제 명령이 필요할 때까지 지연합니다.
# 로컬 개발에서는 앱 부팅이 조금 더 유연해져 true를 권장합니다.
REDIS_LAZY_CONNECT=true

# OpenAI
# OpenAI Platform에서 발급받은 API key입니다.
# 실제 값은 .env에만 넣고 .env.example에는 비워둡니다.
OPENAI_API_KEY=

# 전사에 사용할 OpenAI STT 모델명입니다.
# 기본값은 gpt-4o-transcribe입니다.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# 기본 전사 언어입니다. 업로드 요청에서 language를 주지 않으면 이 값을 사용합니다.
# 한국어는 ko, 영어는 en처럼 ISO 언어 코드를 사용합니다.
DEFAULT_TRANSCRIPTION_LANGUAGE=ko

# Notion
# Notion internal integration의 access token입니다.
# 실제 값은 .env에만 넣고 .env.example에는 비워둡니다.
NOTION_TOKEN=

# 전사 결과 페이지를 생성할 Notion data source ID입니다.
# Notion 데이터베이스/data source 설정에서 복사한 ID를 넣습니다.
NOTION_DATA_SOURCE_ID=

# Notion API 버전입니다.
# 이 프로젝트는 data source API를 사용하므로 2026-03-11을 기본값으로 둡니다.
NOTION_VERSION=2026-03-11

# Storage
# 업로드 원본, 정규화 파일, 청크 파일, 최종 전사 JSON을 저장할 로컬 디렉터리입니다.
# 상대 경로는 프로젝트 루트 기준입니다. /storage는 .gitignore에 포함되어 있습니다.
STORAGE_ROOT=./storage

# 한 번에 업로드 가능한 원본 파일 최대 크기입니다. 바이트 단위입니다.
# 2147483648은 2GiB입니다. 너무 크게 잡으면 디스크 사용량이 빠르게 늘 수 있습니다.
MAX_UPLOAD_BYTES=2147483648

# OpenAI STT에 보낼 청크 파일의 목표 최대 크기입니다. 바이트 단위입니다.
# OpenAI 파일 업로드 제한에 걸리지 않도록 25MB보다 낮은 24000000 bytes를 기본값으로 둡니다.
# 더 안전하게 운영하고 싶으면 20000000처럼 낮출 수 있습니다.
CHUNK_TARGET_BYTES=24000000

# API
# NestJS API 서버 포트입니다.
# 실행 후 기본 주소는 http://localhost:3000 입니다.
PORT=3000
