# Database
# PostgreSQL 접속 문자열입니다.
# 형식: postgresql://사용자:비밀번호@호스트:포트/DB명?schema=스키마명&connection_limit=최대커넥션수
# - voxion_db: 이 앱이 사용할 데이터베이스 이름입니다. 없으면 먼저 생성해야 합니다.
# - schema=public: Prisma가 사용할 PostgreSQL schema입니다.
# - connection_limit=5: Prisma가 열 수 있는 DB 커넥션 수를 낮게 제한합니다. 개인용 로컬 실행이면 5면 충분합니다.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/voxion_db?schema=public&connection_limit=5"

# Redis Configuration
# BullMQ 작업 큐가 사용할 Redis 설정입니다.
# 다른 프로젝트와 같은 Redis를 공유할 때는 REDIS_KEY_PREFIX를 다르게 잡아 큐 키 충돌을 피합니다.
REDIS_KEY_PREFIX=local:

# Redis 서버 위치입니다. Docker Redis를 로컬 포트로 열어둔 경우 localhost를 사용합니다.
REDIS_HOST=localhost

# Redis 포트입니다. 기본 Redis 포트는 6379입니다.
REDIS_PORT=6379

# Redis 비밀번호입니다. 비밀번호가 없으면 빈 값으로 둡니다.
# 예: REDIS_PASSWORD=redis123
REDIS_PASSWORD=

# Redis logical database 번호입니다. 같은 Redis 안에서 앱별로 DB를 나누고 싶을 때 변경합니다.
REDIS_DB=0

# Redis 캐시성 데이터의 기본 TTL 초 단위입니다. 현재 설정값 300은 5분입니다.
REDIS_TTL=300

# Redis 명령 재시도 횟수입니다. 로컬 개발에서는 3 정도면 충분합니다.
REDIS_MAX_RETRIES=3

# Redis 연결 타임아웃입니다. 밀리초 단위이며 10000은 10초입니다.
REDIS_CONNECT_TIMEOUT=10000

# true면 Redis 연결을 실제 명령이 필요할 때까지 지연합니다.
# 로컬 개발에서는 앱 부팅이 조금 더 유연해져 true를 권장합니다.
REDIS_LAZY_CONNECT=true

# OpenAI
# OpenAI Platform에서 발급받은 API key입니다.
# 실제 값은 .env에만 넣고 .env.example에는 비워둡니다.
OPENAI_API_KEY=

# 전사에 사용할 OpenAI STT 모델명입니다.
# 기본값은 gpt-4o-transcribe입니다.
# 현재 추천값은 gpt-4o-transcribe입니다. diarize 모델은 speaker label은 주지만
# prompt와 timestamp granularities를 지원하지 않고 품질이 흔들릴 수 있어 기본 추천값이 아닙니다.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# STT 자체에 전달할 힌트입니다.
# 회의에서 자주 나오는 제품명, 사람/팀 이름, 약어, 기술 용어를 적어두면
# 모델이 비슷한 발음의 다른 단어로 바꾸는 문제를 줄일 수 있습니다.
# 예: OPENAI_TRANSCRIPTION_PROMPT="한국어 회의 녹취입니다. 자주 나오는 용어: CMT, Notion, PostgreSQL, Prisma."
OPENAI_TRANSCRIPTION_PROMPT=

# 청크를 나눠 전사할 때 이전 청크의 마지막 transcript를 다음 청크 prompt에 붙이는 길이입니다.
# 글자 수 기준이며, 0으로 두면 이전 청크 문맥을 전달하지 않습니다.
# chunk boundary 근처의 문맥 단절을 줄이기 위한 값입니다.
OPENAI_TRANSCRIPTION_CONTEXT_CHARS=1200

# STT 완료 후 텍스트 보정용 OpenAI 텍스트 모델 호출을 사용할지 여부입니다.
# true로 켜면 녹음 1건당 추가 OpenAI 호출 비용이 발생합니다.
# false면 STT 결과를 merge한 뒤 시간코드만 붙여 Notion에 올립니다.
OPENAI_POST_PROCESSING_ENABLED=false

# 후처리에 사용할 OpenAI 텍스트 모델입니다.
# 품질 우선이면 gpt-4.1, 비용/속도 우선이면 gpt-4.1-mini 같은 모델을 검토할 수 있습니다.
OPENAI_POST_PROCESSING_MODEL=gpt-4.1

# 후처리 모델에 전달할 보정 지침입니다.
# 요약이 아니라 STT 오류, 띄어쓰기, 문장부호, 문단만 보정하도록 적는 것을 권장합니다.
# 비워두면 앱의 기본 보정 지침과 OPENAI_TRANSCRIPTION_PROMPT를 함께 사용합니다.
OPENAI_POST_PROCESSING_PROMPT=

# 긴 transcript를 후처리 모델에 나눠 보낼 최대 입력 글자 수입니다.
# 너무 낮추면 호출 수가 늘고, 너무 높이면 모델 context 한도에 가까워질 수 있습니다.
OPENAI_POST_PROCESSING_MAX_INPUT_CHARS=24000

# 후처리 1건에서 허용할 최대 OpenAI 텍스트 모델 호출 수입니다.
# 예상 호출 수가 이 값을 넘으면 후처리를 건너뛰고 raw transcript로 완료해 비용 폭주를 막습니다.
OPENAI_POST_PROCESSING_MAX_CHUNKS=8

# 기본 전사 언어입니다. 업로드 요청에서 language를 주지 않으면 이 값을 사용합니다.
# 한국어는 ko, 영어는 en처럼 ISO 언어 코드를 사용합니다.
DEFAULT_TRANSCRIPTION_LANGUAGE=ko

# Notion
# Notion internal integration의 access token입니다.
# 실제 값은 .env에만 넣고 .env.example에는 비워둡니다.
NOTION_TOKEN=

# 전사 결과 페이지를 생성할 Notion table data source ID입니다.
# Notion 페이지 Copy link에서 보이는 database ID가 아니라,
# database 안의 table data source ID를 넣습니다.
NOTION_TABLE_DATA_SOURCE_ID=

# Notion API 버전입니다.
# 이 프로젝트는 data source API를 사용하므로 2026-03-11을 기본값으로 둡니다.
NOTION_VERSION=2026-03-11

# Storage
# 업로드 원본, 정규화 파일, 청크 파일, 전사 JSON을 저장할 로컬 디렉터리입니다.
# 정상 완료 후 원본/정규화/청크/raw JSON은 정리되고 final.json만 남습니다.
# 상대 경로는 프로젝트 루트 기준입니다. /storage는 .gitignore에 포함되어 있습니다.
STORAGE_ROOT=./storage

# 한 번에 업로드 가능한 원본 파일 최대 크기입니다. 바이트 단위입니다.
# 2147483648은 2GiB입니다. 너무 크게 잡으면 디스크 사용량이 빠르게 늘 수 있습니다.
MAX_UPLOAD_BYTES=2147483648

# OpenAI STT에 보낼 청크 파일의 목표 최대 크기입니다. 바이트 단위입니다.
# OpenAI 파일 업로드 제한에 걸리지 않도록 25MB보다 낮은 24000000 bytes를 기본값으로 둡니다.
# 더 안전하게 운영하고 싶으면 20000000처럼 낮출 수 있습니다.
CHUNK_TARGET_BYTES=24000000

# OpenAI STT에 보낼 청크 파일의 목표 최대 길이입니다. 초 단위입니다.
# 현재 모델의 긴 오디오 제한에 걸리지 않도록 1400초보다 낮은 1200초를 기본값으로 둡니다.
# gpt-4o-transcribe-diarize는 처리 시간이 더 길 수 있으므로 600초 이하를 권장합니다.
CHUNK_MAX_DURATION_SECONDS=1200

# Admin Auth
# 브라우저 업로드 화면과 recordings/jobs API를 보호하는 관리자 계정입니다.
# 비워두면 로그인과 보호된 API 접근이 모두 막히므로 운영 환경에서는 반드시 설정합니다.
ADMIN_USERNAME=

# 관리자 비밀번호입니다. 실제 값은 .env 또는 NAS의 .env.prod에만 넣습니다.
ADMIN_PASSWORD=

# 관리자 세션 쿠키 서명용 비밀값입니다. 최소 32자 이상의 랜덤 문자열을 권장합니다.
# 생성 예: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# 관리자 로그인 세션 유지 시간입니다. 초 단위이며 86400은 24시간입니다.
ADMIN_SESSION_TTL_SECONDS=86400

# HTTPS에서만 쿠키를 전송하려면 true로 설정합니다.
# 로컬 HTTP 개발 환경에서는 false로 둡니다.
ADMIN_COOKIE_SECURE=false

# 다른 프로젝트나 스크립트가 API를 호출할 때 사용할 bearer/API key입니다.
# 설정하면 Authorization: Bearer <token> 또는 X-API-Key: <token>으로 보호된 API를 호출할 수 있습니다.
API_ACCESS_TOKEN=

# API
# NestJS API 서버 포트입니다.
# 실행 후 기본 주소는 http://localhost:3000 입니다.
PORT=3000
